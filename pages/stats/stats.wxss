.container {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 120rpx;
}

.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 40rpx 40rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.stats-overview {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 0 24rpx;
  margin-top: -20rpx;
}

.overview-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.overview-card.main-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.overview-card.main-card .card-label,
.overview-card.main-card .card-value {
  color: #ffffff;
}

.card-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.card-content {
  flex: 1;
}

.card-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #2d3436;
  display: block;
}

.card-label {
  font-size: 24rpx;
  color: #95a5a6;
}

.section {
  padding: 24rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #2d3436;
}

.chart-container {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.chart-bars {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  height: 300rpx;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.bar-wrapper {
  width: 40rpx;
  height: 220rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  display: flex;
  align-items: flex-end;
  margin-bottom: 12rpx;
}

.bar {
  width: 100%;
  background: linear-gradient(180deg, #ff6b6b 0%, #ee5a24 100%);
  border-radius: 8rpx;
  transition: height 0.5s ease;
}

.bar-label {
  font-size: 22rpx;
  color: #95a5a6;
  margin-bottom: 8rpx;
}

.bar-value {
  font-size: 20rpx;
  color: #666;
}

.pie-chart-container {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  display: flex;
  align-items: center;
}

.pie-chart {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  position: relative;
  background: conic-gradient(
    #ff6b6b 0deg,
    #ff6b6b calc(45 * 3.6deg),
    #00b894 calc(45 * 3.6deg),
    #00b894 calc(75 * 3.6deg),
    #667eea calc(75 * 3.6deg),
    #667eea 360deg
  );
  margin-right: 32rpx;
}

.pie-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 120rpx;
  height: 120rpx;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.center-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #2d3436;
}

.center-label {
  font-size: 20rpx;
  color: #95a5a6;
}

.pie-legend {
  flex: 1;
}

.legend-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.legend-item:last-child {
  margin-bottom: 0;
}

.legend-color {
  width: 24rpx;
  height: 24rpx;
  border-radius: 6rpx;
  margin-right: 12rpx;
}

.legend-name {
  flex: 1;
  font-size: 26rpx;
  color: #2d3436;
}

.legend-value {
  font-size: 26rpx;
  color: #95a5a6;
}

.health-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.health-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.health-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.health-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #2d3436;
  margin-bottom: 8rpx;
}

.health-label {
  font-size: 24rpx;
  color: #95a5a6;
}