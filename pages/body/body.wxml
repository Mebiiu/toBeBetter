<view class="container">
  <view class="header">
    <view class="header-content">
      <text class="title">减脂餐记录</text>
      <text class="subtitle">记录饮食，健康减脂</text>
    </view>
    <view class="add-btn" bindtap="showAddModal">
      <text class="add-icon">+</text>
    </view>
  </view>

  <view class="meal-stats">
    <view class="stat-item">
      <text class="stat-value">{{totalCalories}}</text>
      <text class="stat-label">今日热量</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{totalProtein}}</text>
      <text class="stat-label">蛋白质(g)</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{totalCarbs}}</text>
      <text class="stat-label">碳水(g)</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{totalFat}}</text>
      <text class="stat-label">脂肪(g)</text>
    </view>
  </view>

  <view class="meal-list" wx:if="{{mealList.length > 0}}">
    <view class="meal-item" wx:for="{{mealList}}" wx:key="id">
      <view class="meal-type {{item.type}}">
        <text>{{item.typeText}}</text>
      </view>
      <view class="meal-content">
        <text class="meal-name">{{item.name}}</text>
        <view class="meal-nutrition">
          <text class="nutrition-item">🔥{{item.calories}}kcal</text>
          <text class="nutrition-item">🍗{{item.protein}}g</text>
          <text class="nutrition-item">🍞{{item.carbs}}g</text>
          <text class="nutrition-item">🥑{{item.fat}}g</text>
        </view>
        <text class="meal-time">{{item.datetime}}</text>
      </view>
      <view class="meal-delete" bindtap="deleteMeal" data-id="{{item.id}}">
        <text>删除</text>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <text class="empty-icon">🍽️</text>
    <text class="empty-text">还没有餐食记录</text>
    <text class="empty-hint">点击右上角 + 开始记录吧</text>
  </view>

  <view class="modal" wx:if="{{showModal}}" bindtap="onModalMaskTap">
    <view class="modal-content" catchtap="true">
      <view class="modal-header">
        <text class="modal-title">添加餐食</text>
        <text class="modal-close" bindtap="hideModal">×</text>
      </view>
      
      <scroll-view class="modal-body" scroll-y="true">
        <view class="type-selector">
          <text class="type-label">餐食类型：</text>
          <view class="type-options">
            <view class="type-option {{mealType === 'breakfast' ? 'active' : ''}}" bindtap="selectMealType" data-type="breakfast">🍳 早餐</view>
            <view class="type-option {{mealType === 'lunch' ? 'active' : ''}}" bindtap="selectMealType" data-type="lunch">🍛 午餐</view>
            <view class="type-option {{mealType === 'dinner' ? 'active' : ''}}" bindtap="selectMealType" data-type="dinner">🍱 晚餐</view>
            <view class="type-option {{mealType === 'snack' ? 'active' : ''}}" bindtap="selectMealType" data-type="snack">🍪 加餐</view>
          </view>
        </view>
        
        <view class="category-selector">
          <text class="section-title">选择食物类别</text>
          <view class="category-options">
            <view class="category-option {{selectedCategory === 'vegetables' ? 'active' : ''}}" bindtap="selectCategory" data-category="vegetables">🥬 蔬菜</view>
            <view class="category-option {{selectedCategory === 'protein' ? 'active' : ''}}" bindtap="selectCategory" data-category="protein">🍗 蛋白质</view>
            <view class="category-option {{selectedCategory === 'carbs' ? 'active' : ''}}" bindtap="selectCategory" data-category="carbs">🍞 碳水</view>
            <view class="category-option {{selectedCategory === 'fruits' ? 'active' : ''}}" bindtap="selectCategory" data-category="fruits">🍎 水果</view>
            <view class="category-option {{selectedCategory === 'fats' ? 'active' : ''}}" bindtap="selectCategory" data-category="fats">🥑 脂肪</view>
          </view>
        </view>
        
        <view class="food-selector" wx:if="{{currentCategoryFoods.length > 0}}">
          <text class="section-title">选择食物</text>
          <view class="food-grid">
            <view class="food-item {{selectedFood === item.name ? 'active' : ''}}" wx:for="{{currentCategoryFoods}}" wx:key="name" bindtap="selectFood" data-food="{{item.name}}">
              <text>{{item.name}}</text>
            </view>
          </view>
        </view>
        
        <view class="weight-input" wx:if="{{selectedFood}}">
          <text class="section-title">输入重量 (克)</text>
          <view class="weight-input-group">
            <input class="weight-input-field" type="number" placeholder="请输入重量" value="{{foodWeight}}" bindinput="onWeightInput" />
            <text class="weight-unit">克</text>
          </view>
          <button class="btn-add-food" bindtap="addFoodItem">+ 添加到餐食</button>
        </view>
        
        <view class="food-list-section" wx:if="{{foodItems.length > 0}}">
          <text class="section-title">已添加食物 ({{foodItems.length}})</text>
          <view class="food-list">
            <view class="food-item" wx:for="{{foodItems}}" wx:key="id">
              <view class="food-info">
                <text class="food-name">{{item.name}} ({{item.weight}}g)</text>
                <text class="food-calories">{{item.calories}} kcal</text>
              </view>
              <view class="food-delete" bindtap="deleteFoodItem" data-id="{{item.id}}">
                <text>×</text>
              </view>
            </view>
          </view>
          <view class="food-total">
            <view class="total-row">
              <text class="total-label">热量：</text>
              <text class="total-value">{{tempTotalCalories}} kcal</text>
            </view>
            <view class="total-row">
              <text class="total-label">蛋白质：</text>
              <text class="total-value">{{tempTotalProtein}}g</text>
            </view>
            <view class="total-row">
              <text class="total-label">碳水：</text>
              <text class="total-value">{{tempTotalCarbs}}g</text>
            </view>
            <view class="total-row">
              <text class="total-label">脂肪：</text>
              <text class="total-value">{{tempTotalFat}}g</text>
            </view>
          </view>
        </view>
      </scroll-view>
      
      <view class="modal-footer">
        <button class="btn-cancel" bindtap="hideModal">取消</button>
        <button class="btn-save" bindtap="saveMeal">保存</button>
      </view>
    </view>
  </view>
</view>