<view class="container">
  <view class="header">
    <view class="header-content">
      <text class="title">减脂餐记录</text>
      <text class="subtitle">记录饮食，健康减脂</text>
    </view>
    <view class="add-btn" bindtap="showAddModal">
      <text class="add-icon">+</text>
    </view>
  </view>

  <view class="meal-stats">
    <view class="stat-item">
      <text class="stat-value">{{totalCalories}}</text>
      <text class="stat-label">今日热量</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{totalProtein}}</text>
      <text class="stat-label">蛋白质(g)</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{totalCarbs}}</text>
      <text class="stat-label">碳水(g)</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{totalFat}}</text>
      <text class="stat-label">脂肪(g)</text>
    </view>
  </view>

  <view class="meal-list" wx:if="{{mealList.length > 0}}">
    <view class="meal-item" wx:for="{{mealList}}" wx:key="id">
      <view class="meal-type {{item.type}}">
        <text>{{item.typeText}}</text>
      </view>
      <view class="meal-content">
        <text class="meal-name">{{item.name}}</text>
        <view class="meal-nutrition">
          <text class="nutrition-item">🔥{{item.calories}}kcal</text>
          <text class="nutrition-item">🍗{{item.protein}}g</text>
          <text class="nutrition-item">🍞{{item.carbs}}g</text>
          <text class="nutrition-item">🥑{{item.fat}}g</text>
        </view>
        <text class="meal-time">{{item.date}} {{item.time}}</text>
      </view>
      <view class="meal-delete" bindtap="deleteMeal" data-id="{{item.id}}">
        <text>删除</text>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <text class="empty-icon">🍽️</text>
    <text class="empty-text">还没有餐食记录</text>
    <text class="empty-hint">点击右上角 + 开始记录吧</text>
  </view>

  <view class="modal" wx:if="{{showModal}}" bindtap="onModalMaskTap">
    <view class="modal-content" catchtap="true">
      <view class="modal-header">
        <text class="modal-title">添加餐食</text>
        <text class="modal-close" bindtap="hideModal">×</text>
      </view>
      <scroll-view class="modal-body" scroll-y="true">
        <view class="type-selector">
          <text class="type-label">餐食类型：</text>
          <view class="type-options">
            <view class="type-option {{newMeal.type === 'breakfast' ? 'active' : ''}}" bindtap="selectMealType" data-type="breakfast">🍳 早餐</view>
            <view class="type-option {{newMeal.type === 'lunch' ? 'active' : ''}}" bindtap="selectMealType" data-type="lunch">🍛 午餐</view>
            <view class="type-option {{newMeal.type === 'dinner' ? 'active' : ''}}" bindtap="selectMealType" data-type="dinner">🍱 晚餐</view>
            <view class="type-option {{newMeal.type === 'snack' ? 'active' : ''}}" bindtap="selectMealType" data-type="snack">🍪 加餐</view>
          </view>
        </view>
        
        <input class="input-item" placeholder="餐食名称" value="{{newMeal.name}}" bindinput="onNameInput" />
        
        <view class="nutrition-inputs">
          <view class="nutrition-item">
            <text class="nutrition-label">热量(kcal)</text>
            <input class="nutrition-input" type="number" placeholder="0" value="{{newMeal.calories}}" bindinput="onCaloriesInput" />
          </view>
          <view class="nutrition-item">
            <text class="nutrition-label">蛋白质(g)</text>
            <input class="nutrition-input" type="number" placeholder="0" value="{{newMeal.protein}}" bindinput="onProteinInput" />
          </view>
          <view class="nutrition-item">
            <text class="nutrition-label">碳水(g)</text>
            <input class="nutrition-input" type="number" placeholder="0" value="{{newMeal.carbs}}" bindinput="onCarbsInput" />
          </view>
          <view class="nutrition-item">
            <text class="nutrition-label">脂肪(g)</text>
            <input class="nutrition-input" type="number" placeholder="0" value="{{newMeal.fat}}" bindinput="onFatInput" />
          </view>
        </view>
      </scroll-view>
      <view class="modal-footer">
        <button class="btn-cancel" bindtap="hideModal">取消</button>
        <button class="btn-save" bindtap="saveMeal">保存</button>
      </view>
    </view>
  </view>
</view>