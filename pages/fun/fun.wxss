.container {
  min-height: 100vh;
  background-color: #f5f7fa;
}

.header {
  background: linear-gradient(135deg, #fd79a8 0%, #e84393 100%);
  padding: 60rpx 40rpx 80rpx;
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
}

.title {
  font-size: 56rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

.function-list {
  padding: 40rpx 30rpx;
}

.function-item {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
}

.function-item:active {
  transform: scale(0.98);
}

.function-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 28rpx;
}

.talkshow-icon {
  background: linear-gradient(135deg, #fd79a8 0%, #e84393 100%);
}

.function-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.function-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #2d3436;
  margin-bottom: 8rpx;
}

.function-desc {
  font-size: 26rpx;
  color: #636e72;
}

.function-arrow {
  font-size: 56rpx;
  color: #b2bec3;
  font-weight: 300;
}