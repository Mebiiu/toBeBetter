<view class="container">
  <view class="header">
    <view class="header-content">
      <text class="title">觉察日记</text>
      <text class="subtitle">记录当下，觉察自我</text>
    </view>
    <view class="add-btn" bindtap="showAddModal">
      <text class="add-icon">+</text>
    </view>
  </view>

  <view class="diary-list" wx:if="{{diaryList.length > 0}}">
    <view class="diary-item" wx:for="{{diaryList}}" wx:key="id" bindtap="viewDiary" data-id="{{item.id}}">
      <view class="diary-date">
        <text class="date-day">{{item.day}}</text>
        <text class="date-month">{{item.month}}</text>
      </view>
      <view class="diary-content">
        <text class="diary-title">{{item.title || '无标题'}}</text>
        <text class="diary-preview">{{item.objective || item.emotion || item.awareness || item.action || '点击查看详情'}}</text>
        <text class="diary-time">{{item.time}}</text>
      </view>
      <view class="diary-mood {{item.mood}}">
        <text>{{item.moodText}}</text>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <text class="empty-icon">📝</text>
    <text class="empty-text">还没有日记哦</text>
    <text class="empty-hint">点击右上角 + 开始记录吧</text>
  </view>

  <!-- 添加日记弹窗 -->
  <view class="modal" wx:if="{{showModal}}" bindtap="onModalMaskTap">
    <view class="modal-content" catchtap="true">
      <view class="modal-header">
        <text class="modal-title">写日记</text>
        <text class="modal-close" bindtap="hideModal">×</text>
      </view>
      
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{progressPercent}}%"></view>
      </view>
      <text class="progress-text">{{progressPercent}}% 完成</text>
      
      <scroll-view class="modal-body" scroll-y="true">
        <input class="input-title" placeholder="给今天起个标题..." value="{{newTitle}}" bindinput="onTitleInput" confirm-type="done" bindconfirm="onInputConfirm" />
        <view class="mood-selector">
          <text class="mood-label">今天的心情：</text>
          <view class="mood-options">
            <view class="mood-option {{newMood === 'happy' ? 'active' : ''}}" bindtap="selectMood" data-mood="happy">😊</view>
            <view class="mood-option {{newMood === 'calm' ? 'active' : ''}}" bindtap="selectMood" data-mood="calm">😌</view>
            <view class="mood-option {{newMood === 'sad' ? 'active' : ''}}" bindtap="selectMood" data-mood="sad">😔</view>
            <view class="mood-option {{newMood === 'anxious' ? 'active' : ''}}" bindtap="selectMood" data-mood="anxious">😰</view>
          </view>
        </view>
        
        <view class="template-section">
          <view class="section-label">【客观记录】</view>
          <textarea class="input-section" placeholder="发生了什么事？记录事实，不评判..." value="{{newObjective}}" bindinput="onObjectiveInput" auto-height bindconfirm="onInputConfirm" />
        </view>
        
        <view class="template-section">
          <view class="section-label">【情绪感受】</view>
          <textarea class="input-section" placeholder="你感受到了什么情绪？..." value="{{newEmotion}}" bindinput="onEmotionInput" auto-height bindconfirm="onInputConfirm" />
        </view>
        
        <view class="template-section">
          <view class="section-label">【觉察转念】</view>
          <textarea class="input-section" placeholder="你有什么想法？可以怎么换个角度看？..." value="{{newAwareness}}" bindinput="onAwarenessInput" auto-height bindconfirm="onInputConfirm" />
        </view>
        
        <view class="template-section">
          <view class="section-label">【积极反应】</view>
          <textarea class="input-section" placeholder="接下来你想怎么做？..." value="{{newAction}}" bindinput="onActionInput" auto-height bindconfirm="onInputConfirm" />
        </view>
      </scroll-view>
      
      <view class="modal-footer">
        <button class="btn-cancel" bindtap="hideModal">取消</button>
        <button class="btn-save" bindtap="saveDiary">保存</button>
      </view>
    </view>
  </view>
</view>