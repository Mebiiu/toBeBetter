.container {
  min-height: 100vh;
  background-color: #f5f7fa;
}

.header {
  background: linear-gradient(135deg, #a29bfe 0%, #6c5ce7 100%);
  padding: 40rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-content {
  flex: 1;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.add-btn {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 48rpx;
  color: #ffffff;
  font-weight: 300;
  line-height: 1;
}

.test-btn {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
}

.test-btn text {
  font-size: 24rpx;
  color: #ffffff;
}

.diary-list {
  padding: 30rpx;
}

.diary-item {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  position: relative;
}

.diary-main {
  flex: 1;
  display: flex;
  align-items: center;
  overflow: hidden;
}

.diary-actions {
  flex-shrink: 0;
  margin-left: 20rpx;
  z-index: 10;
}

.action-btn {
  width: 120rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #6c5ce7;
  border-radius: 35rpx;
  cursor: pointer;
}

.action-icon {
  font-size: 36rpx;
}

.diary-date {
  width: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 24rpx;
}

.date-day {
  font-size: 40rpx;
  font-weight: bold;
  color: #2d3436;
}

.date-month {
  font-size: 24rpx;
  color: #636e72;
}

.diary-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.diary-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d3436;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.diary-preview {
  font-size: 26rpx;
  color: #636e72;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.diary-time {
  font-size: 22rpx;
  color: #b2bec3;
}

.diary-mood {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-left: 16rpx;
}

.diary-mood.happy {
  background: linear-gradient(135deg, #ffeaa7 0%, #fdcb6e 100%);
  color: #d63031;
}

.diary-mood.calm {
  background: linear-gradient(135deg, #81ecec 0%, #00cec9 100%);
  color: #0984e3;
}

.diary-mood.sad {
  background: linear-gradient(135deg, #dfe6e9 0%, #b2bec3 100%);
  color: #636e72;
}

.diary-mood.anxious {
  background: linear-gradient(135deg, #fab1a0 0%, #e17055 100%);
  color: #d63031;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #636e72;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #b2bec3;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
  padding: 0;
}

.modal-content {
  width: 100%;
  max-height: 85vh;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.modal-header {
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #f1f2f6;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d3436;
}

.modal-close {
  font-size: 48rpx;
  color: #b2bec3;
  font-weight: 300;
  line-height: 1;
}

.modal-body {
  padding: 20rpx 0;
  flex: 1;
  overflow-y: auto;
  max-height: 65vh;
}

.input-title {
  width: 92%;
  height: 80rpx;
  padding: 0 24rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 28rpx;
  margin-bottom: 24rpx;
  margin-left: 4%;
  margin-right: 4%;
  box-sizing: border-box;
  background: #ffffff;
  color: #333333;
  line-height: 80rpx;
}

.mood-selector {
  margin-bottom: 24rpx;
  padding: 0 4%;
}

.mood-label {
  font-size: 28rpx;
  color: #2d3436;
  display: block;
  margin-bottom: 16rpx;
}

.mood-options {
  display: flex;
  gap: 24rpx;
}

.mood-option {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #f1f2f6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  border: 4rpx solid transparent;
}

.mood-option.active {
  border-color: #6c5ce7;
  background: #e8e6ff;
}

.template-section {
  margin-bottom: 24rpx;
  padding: 0 4%;
}

.section-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #6c5ce7;
  margin-bottom: 12rpx;
}

.input-section {
  width: 100%;
  min-height: 140rpx;
  padding: 24rpx;
  border: 1rpx solid #dfe6e9;
  border-radius: 12rpx;
  font-size: 28rpx;
  background-color: #fafafa;
  box-sizing: border-box;
}

.modal-footer {
  padding: 20rpx 30rpx;
  display: flex;
  gap: 20rpx;
  border-top: 1rpx solid #f1f2f6;
  background: #ffffff;
}

.modal-footer button {
  flex: 1;
  border-radius: 44rpx;
  font-size: 30rpx;
  padding: 24rpx;
}

.btn-cancel {
  background: #f1f2f6;
  color: #636e72;
}

.btn-save {
  background: linear-gradient(135deg, #a29bfe 0%, #6c5ce7 100%);
  color: #ffffff;
}

.preview-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.preview-content {
  width: 90%;
  max-width: 700rpx;
  max-height: 85vh;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.preview-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background: #ffffff;
}

.preview-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.preview-close {
  font-size: 48rpx;
  color: #999999;
  line-height: 1;
}

.preview-body {
  flex: 1;
  overflow-y: auto;
  background: #f9f7f4;
}

.preview-doc {
  padding: 40rpx;
  background: #fefcf7;
  min-height: 600rpx;
  border-radius: 24rpx;
}

.doc-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #2d2d2d;
  margin-bottom: 24rpx;
}

.doc-meta {
  display: flex;
  gap: 40rpx;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 24rpx;
}

.section-divider {
  height: 2rpx;
  background: linear-gradient(to right, #e8e0d5, transparent);
  margin-bottom: 32rpx;
}

.doc-section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-line {
  width: 8rpx;
  height: 32rpx;
  background: #d4cfc5;
  margin-right: 16rpx;
}

.section-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.section-label {
  font-size: 28rpx;
  color: #8b7355;
  font-weight: 500;
}

.section-content-white {
  background: #ffffff;
  padding: 28rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.8;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.section-content-gray {
  background: #f5f2eb;
  padding: 28rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.8;
}

.emotion-tags {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.emotion-tag {
  background: #ffe4d6;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #c47b5e;
}

.doc-footer {
  padding-top: 24rpx;
  margin-top: 24rpx;
  border-top: 1rpx solid #e8e0d5;
}

.qrcode-container {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 24rpx;
}

.qrcode {
  width: 120rpx;
  height: 120rpx;
  background: #ffffff;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.qrcode-icon {
  font-size: 48rpx;
}

.qrcode-text {
  font-size: 20rpx;
  color: #666666;
  margin-top: 8rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #999999;
}

.action-text {
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 500;
}