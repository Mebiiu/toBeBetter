.container {
  min-height: 100vh;
}

.banner {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 40rpx 80rpx;
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.banner-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.banner-title {
  font-size: 56rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.banner-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

.section-container {
  padding: 40rpx 30rpx;
}

.section {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
}

.section:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.section-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 28rpx;
}

.body-icon {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
}

.mind-icon {
  background: linear-gradient(135deg, #54a0ff 0%, #0984e3 100%);
}

.fun-icon {
  background: linear-gradient(135deg, #feca57 0%, #ff9ff3 100%);
}

.section-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #2d3436;
  margin-bottom: 8rpx;
}

.section-desc {
  font-size: 26rpx;
  color: #636e72;
}

.section-arrow {
  font-size: 56rpx;
  color: #b2bec3;
  font-weight: 300;
}
