.container {
  padding: 0;
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 120rpx;
}

.banner {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
  padding: 60rpx 40rpx 80rpx;
  position: relative;
  overflow: hidden;
}

.banner-content {
  text-align: center;
  z-index: 1;
  position: relative;
}

.date {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 16rpx;
  display: block;
}

.title {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 24rpx;
  display: block;
}

.calories-display {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.calories-value {
  font-size: 88rpx;
  font-weight: bold;
  color: #ffffff;
}

.calories-unit {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-left: 8rpx;
}

.calories-info {
  margin-top: 16rpx;
}

.calories-info text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.progress-ring {
  position: absolute;
  right: 40rpx;
  top: 60rpx;
  width: 120rpx;
  height: 120rpx;
}

.progress-bg {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
}

.progress-fill {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: conic-gradient(#ffffff var(--progress), transparent var(--progress));
  mask: radial-gradient(transparent 60%, #000 61%);
  -webkit-mask: radial-gradient(transparent 60%, #000 61%);
}

.progress-inner {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
}

.progress-text {
  font-size: 20rpx;
  font-weight: bold;
  color: #ff6b6b;
}

.stats-row {
  display: flex;
  justify-content: space-around;
  background: #ffffff;
  margin: -40rpx 24rpx 24rpx;
  padding: 32rpx 0;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 2;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-bottom: 12rpx;
}

.food-icon {
  background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
}

.exercise-icon {
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
}

.balance-icon {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.stat-info {
  text-align: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #2d3436;
  display: block;
}

.stat-value.balance {
  color: #ff6b6b;
}

.stat-label {
  font-size: 24rpx;
  color: #95a5a6;
}

.section {
  padding: 0 24rpx;
}

.section-header {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2d3436;
}

.record-list {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: #f8f9fa;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 20rpx;
}

.record-content {
  flex: 1;
}

.record-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d3436;
  display: block;
  margin-bottom: 4rpx;
}

.record-desc {
  font-size: 24rpx;
  color: #95a5a6;
}

.record-calories {
  font-size: 26rpx;
  font-weight: 600;
}

.record-calories .positive {
  color: #ff6b6b;
}

.record-calories .negative {
  color: #00b894;
}

.empty-state {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 60rpx 0;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #2d3436;
  display: block;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #95a5a6;
}