.container {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 120rpx;
}

.header {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
  padding: 60rpx 40rpx 32rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.nutrition-guide {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx 24rpx;
  gap: 12rpx;
  background: rgba(255, 255, 255, 0.2);
  margin: 0 24rpx;
  border-radius: 16rpx;
}

.guide-item {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 20rpx;
}

.guide-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.guide-text {
  font-size: 20rpx;
  color: #ffffff;
}

.search-bar {
  background: #ffffff;
  margin: 20rpx 24rpx;
  padding: 0 24rpx;
  border-radius: 40rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
}

.search-icon {
  font-size: 32rpx;
}

.category-tabs {
  display: flex;
  justify-content: space-around;
  padding: 0 24rpx;
  margin-bottom: 24rpx;
}

.category-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
  min-width: 140rpx;
}

.category-tab.active {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
}

.category-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.category-name {
  font-size: 24rpx;
  color: #666;
}

.category-tab.active .category-name {
  color: #ffffff;
}

.food-list {
  padding: 0 24rpx;
}

.food-item {
  display: flex;
  align-items: flex-start;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.food-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.food-info {
  flex: 1;
}

.food-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d3436;
  display: block;
  margin-bottom: 4rpx;
}

.food-desc {
  font-size: 24rpx;
  color: #95a5a6;
  display: block;
  margin-bottom: 8rpx;
}

.food-nutrition {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.nutrition-tag {
  font-size: 20rpx;
  color: #666;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.food-calories {
  text-align: right;
}

.food-calories .calories {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff6b6b;
  display: block;
}

.food-calories .unit {
  font-size: 20rpx;
  color: #95a5a6;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2d3436;
}

.modal-close {
  font-size: 48rpx;
  color: #95a5a6;
  line-height: 1;
}

.modal-body {
  padding: 32rpx;
}

.selected-food {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.selected-icon {
  font-size: 64rpx;
  margin-right: 20rpx;
}

.selected-info {
  flex: 1;
}

.selected-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #2d3436;
  display: block;
  margin-bottom: 8rpx;
}

.selected-unit {
  font-size: 26rpx;
  color: #95a5a6;
}

.nutrition-detail {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.detail-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #2d3436;
  display: block;
  margin-bottom: 16rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #e0e0e0;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 26rpx;
  color: #666;
}

.detail-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #2d3436;
}

.portion-section {
  margin-bottom: 24rpx;
}

.portion-label {
  font-size: 28rpx;
  color: #2d3436;
  margin-bottom: 20rpx;
  display: block;
}

.portion-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
}

.portion-btn {
  width: 80rpx;
  height: 80rpx;
  background: #f0f0f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #666;
}

.portion-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #2d3436;
  min-width: 80rpx;
  text-align: center;
}

.total-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #fff5f5 0%, #ffe0e0 100%);
  border-radius: 16rpx;
}

.total-label {
  font-size: 28rpx;
  color: #666;
}

.total-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6b6b;
}

.modal-footer {
  display: flex;
  padding: 24rpx 32rpx;
  gap: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.btn-cancel {
  flex: 1;
  background: #f0f0f0;
  color: #666;
  border: none;
  border-radius: 40rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

.btn-confirm {
  flex: 1;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
  color: #ffffff;
  border: none;
  border-radius: 40rpx;
  padding: 24rpx;
  font-size: 28rpx;
}