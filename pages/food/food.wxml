<view class="container">
  <view class="header">
    <text class="header-title">饮食记录</text>
    <text class="header-subtitle">记录每天的营养摄入</text>
  </view>

  <view class="nutrition-guide">
    <view class="guide-item" wx:for="{{nutritionGuide}}" wx:key="key">
      <text class="guide-icon">{{item.icon}}</text>
      <text class="guide-text">{{item.description}}</text>
    </view>
  </view>

  <view class="search-bar">
    <input class="search-input" placeholder="搜索食物..." value="{{searchText}}" bindinput="onSearchInput" />
    <text class="search-icon">🔍</text>
  </view>

  <view class="category-tabs">
    <view class="category-tab {{currentCategory === 'vegetables' ? 'active' : ''}}" bindtap="selectCategory" data-category="vegetables">
      <text class="category-icon">🥦</text>
      <text class="category-name">蔬菜</text>
    </view>
    <view class="category-tab {{currentCategory === 'protein' ? 'active' : ''}}" bindtap="selectCategory" data-category="protein">
      <text class="category-icon">🍗</text>
      <text class="category-name">蛋白质</text>
    </view>
    <view class="category-tab {{currentCategory === 'fat' ? 'active' : ''}}" bindtap="selectCategory" data-category="fat">
      <text class="category-icon">🥑</text>
      <text class="category-name">脂肪</text>
    </view>
    <view class="category-tab {{currentCategory === 'carbs' ? 'active' : ''}}" bindtap="selectCategory" data-category="carbs">
      <text class="category-icon">🍚</text>
      <text class="category-name">碳水</text>
    </view>
  </view>

  <view class="food-list">
    <view class="food-item" wx:for="{{currentFoodList}}" wx:key="id" bindtap="addFood" data-food="{{item}}">
      <view class="food-icon">{{item.icon}}</view>
      <view class="food-info">
        <text class="food-name">{{item.name}}</text>
        <text class="food-desc">{{item.unit}}</text>
        <view class="food-nutrition">
          <text class="nutrition-tag">蛋白质 {{item.protein}}g</text>
          <text class="nutrition-tag">脂肪 {{item.fat}}g</text>
          <text class="nutrition-tag">碳水 {{item.carbs}}g</text>
        </view>
      </view>
      <view class="food-calories">
        <text class="calories">{{item.calories}}</text>
        <text class="unit">kcal</text>
      </view>
    </view>
  </view>

  <view class="modal" wx:if="{{showModal}}" bindtap="hideModal">
    <view class="modal-content" catchtap="true">
      <view class="modal-header">
        <text class="modal-title">{{isCustom ? '添加自定义食物' : '添加食物'}}</text>
        <text class="modal-close" bindtap="hideModal">×</text>
      </view>
      <view class="modal-body">
        <view wx:if="{{!isCustom}}" class="selected-food">
          <text class="selected-icon">{{selectedFood.icon}}</text>
          <view class="selected-info">
            <text class="selected-name">{{selectedFood.name}}</text>
            <text class="selected-unit">{{selectedFood.unit}}</text>
          </view>
        </view>
        
        <view wx:if="{{isCustom}}" class="custom-input-section">
          <view class="input-row">
            <text class="input-label">食物名称</text>
            <input class="custom-input" placeholder="请输入食物名称" value="{{customFoodName}}" bindinput="onCustomFoodNameInput" />
          </view>
          <view class="input-row">
            <text class="input-label">热量 (kcal)</text>
            <input class="custom-input" type="number" placeholder="请输入热量" value="{{customCalories}}" bindinput="onCustomCaloriesInput" />
          </view>
        </view>

        <view wx:if="{{!isCustom}}" class="nutrition-detail">
          <text class="detail-title">营养成分</text>
          <view class="detail-row">
            <text class="detail-label">热量</text>
            <text class="detail-value">{{selectedFood.calories}} kcal</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">蛋白质</text>
            <text class="detail-value">{{selectedFood.protein}} g</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">脂肪</text>
            <text class="detail-value">{{selectedFood.fat}} g</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">碳水</text>
            <text class="detail-value">{{selectedFood.carbs}} g</text>
          </view>
        </view>

        <view wx:if="{{!isCustom}}" class="portion-section">
          <text class="portion-label">份量</text>
          <view class="portion-controls">
            <view class="portion-btn" bindtap="decreasePortion">−</view>
            <text class="portion-value">{{portion}}</text>
            <view class="portion-btn" bindtap="increasePortion">+</view>
          </view>
        </view>

        <view class="total-section">
          <text class="total-label">总计</text>
          <text class="total-value">{{totalCalories}} kcal</text>
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn-cancel" bindtap="hideModal">取消</button>
        <button class="btn-confirm" bindtap="confirmAdd">确认添加</button>
      </view>
    </view>
  </view>
</view>