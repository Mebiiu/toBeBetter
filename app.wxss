page {
  background-color: #f8f9fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.container {
  padding: 0;
  min-height: 100vh;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.btn-primary {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
  color: #ffffff;
  border: none;
  border-radius: 40rpx;
  padding: 24rpx 48rpx;
  font-size: 28rpx;
}

.btn-secondary {
  background: #f0f0f0;
  color: #333333;
  border: none;
  border-radius: 40rpx;
  padding: 24rpx 48rpx;
  font-size: 28rpx;
}